# PostgreSQL connection (required for Drizzle + Better Auth)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cobroflow"

# Better Auth — min 32 chars; generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# Public URL of this app (no trailing slash). Must match the browser origin in production (HTTPS).
BETTER_AUTH_URL="http://localhost:3000"

# Cron — Bearer token for GET /api/cron/invoices (Vercel Cron sends this when CRON_SECRET is set)
# CRON_SECRET="replace-with-a-long-random-secret-at-least-16-chars"

# Webhooks — encrypts signing secrets at rest (min 16 chars); required to create endpoints and to dispatch signed events
# WEBHOOK_SECRET_ENCRYPTION_KEY="replace-with-a-long-random-secret-at-least-16-chars"

# Optional — concatenated into API key hashing (must stay stable per deployment if set)
# API_KEY_PEPPER=""

# Optional — only if you enable magic link / transactional email later (e.g. Resend)
# RESEND_API_KEY=""
# EMAIL_FROM="CobroFlow <onboarding@example.com>"
